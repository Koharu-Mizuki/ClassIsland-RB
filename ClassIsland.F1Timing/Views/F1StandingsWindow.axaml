<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:ClassIsland.F1Timing.Converters"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
        x:Class="ClassIsland.F1Timing.Views.F1StandingsWindow"
        Title="F1 积分榜" Width="400" Height="600"
        WindowStartupLocation="CenterScreen"
        MinWidth="350" MinHeight="400"
        Background="#08080C"
        FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#E8E8EC" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.mono">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New, monospace" />
        </Style>
        <Style Selector="TextBlock.head">
            <Setter Property="Foreground" Value="#7A7A85" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#14141C" Padding="14,10">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="2025 车手积分榜" FontWeight="Bold" FontSize="15"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="SubtitleText" Foreground="#7A7A85" FontSize="11"
                           HorizontalAlignment="Center" Text="数据来源：Jolpica/Ergast" />
            </StackPanel>
        </Border>

        <!-- Tab 切换 -->
        <Border Grid.Row="1" Background="#0C0C12" Padding="10,4" BorderBrush="#22222C" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="TabDrivers" Content="车手" Classes="head"
                        Click="TabDrivers_Click" Padding="8,2" />
                <Button x:Name="TabConstructors" Content="车队" Classes="head"
                        Click="TabConstructors_Click" Padding="8,2" />
            </StackPanel>
        </Border>

        <!-- 积分榜列表 -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
            <Panel>
                <!-- 车手积分榜 -->
                <ItemsControl x:Name="DriversList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="32" Margin="0,1,0,0" Background="#12121A">
                                <Grid Margin="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="40" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Classes="mono" FontWeight="Bold" FontSize="13"
                                               Text="{Binding Position}" />
                                    <Border Grid.Column="1" Width="4" Height="18" CornerRadius="2"
                                            VerticalAlignment="Center"
                                            Background="{Binding TeamColour, Converter={x:Static conv:HexToBrushConverter.Instance}}" />
                                    <TextBlock Grid.Column="2" FontWeight="Bold" FontSize="12"
                                               Text="{Binding Tla}" Margin="6,0,0,0" />
                                    <TextBlock Grid.Column="3" FontSize="11" Foreground="#B8B8C0"
                                               Text="{Binding FullName}" />
                                    <TextBlock Grid.Column="4" Classes="mono" FontWeight="Bold" FontSize="13"
                                               HorizontalAlignment="Right"
                                               Text="{Binding Points}" />
                                    <TextBlock Grid.Column="5" Classes="mono" FontSize="10" Foreground="#7A7A85"
                                               HorizontalAlignment="Right"
                                               Text="{Binding Wins, StringFormat='{}W{0}'}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 车队积分榜 -->
                <ItemsControl x:Name="ConstructorsList" IsVisible="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="32" Margin="0,1,0,0" Background="#12121A">
                                <Grid Margin="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="40" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Classes="mono" FontWeight="Bold" FontSize="13"
                                               Text="{Binding Position}" />
                                    <Border Grid.Column="1" Width="4" Height="18" CornerRadius="2"
                                            VerticalAlignment="Center"
                                            Background="{Binding TeamColour, Converter={x:Static conv:HexToBrushConverter.Instance}}" />
                                    <TextBlock Grid.Column="2" FontWeight="SemiBold" FontSize="12"
                                               Text="{Binding TeamName}" Margin="6,0,0,0" />
                                    <TextBlock Grid.Column="3" Classes="mono" FontWeight="Bold" FontSize="13"
                                               HorizontalAlignment="Right"
                                               Text="{Binding Points}" />
                                    <TextBlock Grid.Column="4" Classes="mono" FontSize="10" Foreground="#7A7A85"
                                               HorizontalAlignment="Right"
                                               Text="{Binding Wins, StringFormat='{}W{0}'}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 加载中 / 无数据 -->
                <TextBlock x:Name="LoadingText" Text="正在加载积分数据…"
                           Foreground="#6A6A75" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,60,0,0" />
            </Panel>
        </ScrollViewer>

        <!-- 底部 -->
        <Border Grid.Row="3" Background="#0C0C12" Padding="12,6" BorderBrush="#22222C" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="RefreshButton" Content="刷新" Click="Refresh_Click" Padding="8,2" />
                <TextBlock x:Name="StatusText" Foreground="#7A7A85" FontSize="11" VerticalAlignment="Center"
                           Text="缓存 1 小时" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
