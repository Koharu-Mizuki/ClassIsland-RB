<controls:ComponentBase x:TypeArguments="settings:F1TimingComponentSettings"
                        x:Class="ClassIsland.F1Timing.Controls.F1TimingComponent"
                        xmlns="https://github.com/avaloniaui"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:ClassIsland.F1Timing.Controls"
                        xmlns:controls="clr-namespace:ClassIsland.Core.Abstractions.Controls;assembly=ClassIsland.Core"
                        xmlns:settings="clr-namespace:ClassIsland.F1Timing.Models.Settings"
                        xmlns:models="clr-namespace:ClassIsland.F1Timing.Models"
                        xmlns:conv="clr-namespace:ClassIsland.F1Timing.Converters"
                        mc:Ignorable="d" d:DesignHeight="40" d:DesignWidth="360">
    <controls:ComponentBase.Resources>
        <DataTemplate x:Key="DriverItemTemplate" x:DataType="models:F1DriverTiming">
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,16,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Position}" FontWeight="Bold" VerticalAlignment="Center" />
                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                         Fill="{Binding TeamColour, Converter={x:Static conv:HexToBrushConverter.Instance}}" />
                <TextBlock Text="{Binding Tla}" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>
    </controls:ComponentBase.Resources>

    <Grid DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:F1TimingComponent}}">

        <!-- 横向滚动排位（跑马灯）。IsVisible / Opacity 由代码驱动，避免硬切。 -->
        <Border x:Name="Viewport" ClipToBounds="True" MaxWidth="440" VerticalAlignment="Center"
                IsVisible="False" Opacity="0">
            <StackPanel x:Name="Track" Orientation="Horizontal">
                <ItemsControl x:Name="List1" ItemsSource="{Binding Snapshot.Drivers}"
                              ItemTemplate="{StaticResource DriverItemTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding Snapshot.Drivers}"
                              ItemTemplate="{StaticResource DriverItemTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- 最快圈蒙版：斜切平行四边形从两侧向中央扫入，与系统通知蒙版视觉一致 -->
        <local:SlantedMaskControl x:Name="FastestLapMask"
                                   Fill="#B14BE0"
                                   SlantedHeight="40"
                                   RegionDurationMs="280"
                                   StageStaggerMs="100"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   IsVisible="False" />

        <!-- 最快圈内容：叠在蒙版上方，蒙版打开后淡入 -->
        <DockPanel x:Name="FastestLapContent" Margin="10,0" LastChildFill="False"
                   VerticalAlignment="Center" Opacity="0" IsVisible="False">
            <!-- FASTEST / LAP 双行小字 -->
            <StackPanel DockPanel.Dock="Left" Orientation="Vertical" VerticalAlignment="Center"
                        Spacing="0" Margin="0,0,8,0">
                <TextBlock Text="FASTEST"
                           FontSize="7" FontWeight="Bold" LetterSpacing="1.2"
                           Foreground="White" LineHeight="8.5" />
                <TextBlock Text="LAP"
                           FontSize="7" FontWeight="Bold" LetterSpacing="1.2"
                           Foreground="White" LineHeight="8.5" />
            </StackPanel>
            <!-- 细分割线 -->
            <Border DockPanel.Dock="Left" Width="1" Background="#60FFFFFF" Margin="0,4,8,4" />
            <!-- 车手缩写（大字） -->
            <TextBlock x:Name="FastestLapTlaLabel"
                       DockPanel.Dock="Left"
                       FontSize="13" FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <!-- 圈速（小字偏淡） -->
            <TextBlock x:Name="FastestLapTimeLabel"
                       DockPanel.Dock="Left"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="#DDD0FF"
                       VerticalAlignment="Center" />
        </DockPanel>

    </Grid>
</controls:ComponentBase>
