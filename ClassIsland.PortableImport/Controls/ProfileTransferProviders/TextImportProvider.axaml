<ci:ProfileTransferProviderControlBase xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="700"
             x:Class="ClassIsland.PortableImport.Controls.ProfileTransferProviders.TextImportProvider">
    <ci:ProfileTransferProviderControlBase.Resources>
        <ci:IntToRadioButtonSelectionConverter x:Key="IntToRadioButtonSelectionConverter" />
    </ci:ProfileTransferProviderControlBase.Resources>
    <ScrollViewer>
        <StackPanel Classes="settings-container animated-intro" Spacing="4">

            <!-- 输入课表文字 -->
            <controls:SettingsExpander Header="输入课表文字"
                                       Description="每行一个时间段，格式：08:00-08:45 语文"
                                       IsExpanded="True">
                <controls:SettingsExpanderItem>
                    <StackPanel Spacing="8">
                        <controls:InfoBar Title="格式说明"
                                          Severity="Informational"
                                          IsOpen="True"
                                          IsClosable="False">
                            <StackPanel Spacing="6">
                                <TextBlock TextWrapping="Wrap"
                                           FontFamily="Consolas, monospace"
                                           FontSize="12"
                                           Text="每行一条，格式：08:00-08:45 语文&#10;含「课间」「休息」字样或时间段后无文字 → 课间休息&#10;无时间段的行（标题、注释等）自动忽略"/>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="示例模板："
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="12"/>
                                    <Button Content="神山高校标准上课时间安排表"
                                            FontSize="12"
                                            Padding="6,2,6,2"
                                            Click="ButtonLoadPreset_OnClick"/>
                                </StackPanel>
                            </StackPanel>
                        </controls:InfoBar>
                        <TextBox Text="{Binding InputText}"
                                 AcceptsReturn="True"
                                 MinHeight="160"
                                 MaxHeight="320"
                                 FontFamily="Consolas, monospace"
                                 TextWrapping="NoWrap"/>
                    </StackPanel>
                </controls:SettingsExpanderItem>
            </controls:SettingsExpander>

            <!-- 解析 -->
            <controls:SettingsExpander Header="解析">
                <controls:SettingsExpanderItem>
                    <StackPanel Spacing="10">
                        <Button Content="解析课表"
                                Classes="accent"
                                IsEnabled="{Binding CanParse}"
                                Click="ButtonParse_OnClick"/>
                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding IsParsing}"
                                     Height="4"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   IsVisible="{Binding HasError}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   IsVisible="{Binding HasSuccessMessage}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </controls:SettingsExpanderItem>
            </controls:SettingsExpander>

            <!-- 解析结果 -->
            <controls:SettingsExpander Header="解析结果"
                                       IsVisible="{Binding HasResult}"
                                       IsExpanded="True">
                <controls:SettingsExpanderItem Content="时间表预览">
                    <ItemsControl ItemsSource="{Binding ResultPeriods}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,3" CornerRadius="4">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding Label}"
                                                   Width="60"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{Binding Time}"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Consolas, monospace"/>
                                        <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                CornerRadius="3"
                                                Padding="4,1"
                                                IsVisible="{Binding IsClass}">
                                            <TextBlock Text="上课" Foreground="White" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </controls:SettingsExpanderItem>

                <controls:SettingsExpanderItem Content="课程列表（可编辑）"
                                               Description="直接修改科目名称，导入时将自动创建对应科目">
                    <ItemsControl ItemsSource="{Binding ClassGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="4" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding DayName}"
                                               IsVisible="{Binding HasDayName}"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,2"/>
                                    <ItemsControl ItemsSource="{Binding Classes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                                    <TextBlock Text="{Binding Index, StringFormat='第{0}节'}"
                                                               Width="50"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <TextBox Text="{Binding Name}"
                                                             MinWidth="140"
                                                             Watermark="科目名称（留空跳过）"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </controls:SettingsExpanderItem>
            </controls:SettingsExpander>

            <!-- 导入到 -->
            <controls:SettingsExpander Header="导入到"
                                       IsExpanded="True"
                                       IsEnabled="{Binding HasResult}">
                <controls:SettingsExpanderItem>
                    <RadioButton Content="合并到当前档案"
                                 IsChecked="{Binding ImportType, Converter={StaticResource IntToRadioButtonSelectionConverter}, ConverterParameter=0}"/>
                </controls:SettingsExpanderItem>
                <controls:SettingsExpanderItem>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <RadioButton Content="创建新档案"
                                     IsChecked="{Binding ImportType, Converter={StaticResource IntToRadioButtonSelectionConverter}, ConverterParameter=1}"/>
                        <TextBox Watermark="新档案名称"
                                 Text="{Binding NewProfileName}"
                                 MinWidth="180"
                                 IsVisible="{Binding ImportType, Converter={StaticResource IntToRadioButtonSelectionConverter}, ConverterParameter=1}"/>
                    </StackPanel>
                </controls:SettingsExpanderItem>
                <controls:SettingsExpanderItem Content="课表群">
                    <StackPanel Spacing="6">
                        <ComboBox ItemsSource="{Binding AvailableGroups}"
                                  SelectedItem="{Binding SelectedGroupItem}"
                                  MinWidth="200">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox Text="{Binding ImportGroupName}"
                                 Watermark="新课表群名称"
                                 IsVisible="{Binding IsCreatingNewGroup}"
                                 MinWidth="200"/>
                    </StackPanel>
                </controls:SettingsExpanderItem>
            </controls:SettingsExpander>

        </StackPanel>
    </ScrollViewer>
</ci:ProfileTransferProviderControlBase>
