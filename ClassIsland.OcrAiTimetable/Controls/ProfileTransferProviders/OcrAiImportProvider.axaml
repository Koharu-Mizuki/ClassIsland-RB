<UserControl x:Class="ClassIsland.OcrAiTimetable.Controls.ProfileTransferProviders.OcrAiImportProvider"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:local="clr-namespace:ClassIsland.OcrAiTimetable.Controls.ProfileTransferProviders"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="800"
             d:DataContext="{d:DesignInstance local:OcrAiImportProvider}">

  <UserControl.Resources>
    <ci:IntToRadioButtonSelectionConverter x:Key="IntToRadioButtonSelectionConverter" />
  </UserControl.Resources>

  <ScrollViewer>
    <StackPanel Classes="settings-container animated-intro" Spacing="4">

      <!-- 输入模式选择 -->
      <controls:SettingsExpander Header="选择输入方式"
                                 Description="选择通过图片 AI 识别还是手动输入文字快速导入"
                                 IsExpanded="True">
        <controls:SettingsExpanderItem>
          <StackPanel Spacing="8">
            <RadioButton Content="AI 识别图片（需配置 API）"
                         IsChecked="{Binding IsAiMode}" />
            <RadioButton Content="手动文字输入（无需 API，快速上手）"
                         IsChecked="{Binding IsTextMode}" />
          </StackPanel>
        </controls:SettingsExpanderItem>
      </controls:SettingsExpander>

      <!-- ═══ AI 模式 ═══ -->

      <!-- 第一步：选择图片（仅 AI 模式） -->
      <controls:SettingsExpander Header="第一步：选择课表图片"
                                 Description="支持 PNG、JPG、WEBP 格式的截图或拍照"
                                 IsVisible="{Binding IsAiMode}">
        <controls:SettingsExpander.Footer>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBox Text="{Binding ImagePath}"
                     Watermark="图片路径"
                     MinWidth="240"
                     VerticalAlignment="Center" />
            <Button Content="&#xe88d;"
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    VerticalAlignment="Center"
                    Click="ButtonPickImage_OnClick"
                    ToolTip.Tip="选择图片文件" />
          </StackPanel>
        </controls:SettingsExpander.Footer>

        <!-- 图片预览 -->
        <controls:SettingsExpanderItem IsVisible="{Binding HasImage}">
          <Border CornerRadius="6" ClipToBounds="True"
                  MaxHeight="200" HorizontalAlignment="Left">
            <Image Source="{Binding PreviewBitmap}"
                   Stretch="Uniform"
                   MaxHeight="200"
                   MaxWidth="400" />
          </Border>
        </controls:SettingsExpanderItem>
      </controls:SettingsExpander>

      <!-- AI 提供商信息（仅 AI 模式） -->
      <controls:SettingsExpander Header="第二步：AI 识别"
                                 Description="{Binding ApiSummary}"
                                 IsVisible="{Binding IsAiMode}">
        <controls:SettingsExpanderItem>
          <controls:InfoBar Title="提示"
                            Message="如需更换 AI 服务商或 API 密钥，请前往「插件设置 → OCR 课表导入」。"
                            Severity="Informational"
                            IsOpen="True"
                            IsClosable="False" />
        </controls:SettingsExpanderItem>
      </controls:SettingsExpander>

      <!-- ═══ 文字模式 ═══ -->

      <controls:SettingsExpander Header="手动输入课表文字"
                                 Description="每行一个时间段，格式：08:00-08:45 语文"
                                 IsVisible="{Binding IsTextMode}"
                                 IsExpanded="True">
        <controls:SettingsExpanderItem>
          <StackPanel Spacing="8">
            <controls:InfoBar Title="格式说明"
                              Severity="Informational"
                              IsOpen="True"
                              IsClosable="False">
              <controls:InfoBar.Content>
                <TextBlock TextWrapping="Wrap" FontFamily="Consolas, monospace" FontSize="12"
                           Text="每行一条，格式：08:00-08:45 语文&#x0A;含「课间」字样或时间段后没有文字 → 课间休息&#x0A;示例：&#x0A;  08:00-08:45 语文&#x0A;  08:45-09:00 课间&#x0A;  09:00-09:45 数学" />
              </controls:InfoBar.Content>
            </controls:InfoBar>
            <TextBox Text="{Binding ManualText}"
                     AcceptsReturn="True"
                     MinHeight="160"
                     MaxHeight="320"
                     FontFamily="Consolas, monospace"
                     TextWrapping="NoWrap" />
          </StackPanel>
        </controls:SettingsExpanderItem>
      </controls:SettingsExpander>

      <!-- ═══ 公共：开始处理按钮 ═══ -->
      <controls:SettingsExpander Header="开始处理">
        <controls:SettingsExpanderItem>
          <StackPanel Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="开始 AI 识别"
                      Classes="accent"
                      IsVisible="{Binding IsAiMode}"
                      IsEnabled="{Binding CanRecognize}"
                      Click="ButtonRecognize_OnClick" />
              <Button Content="解析文字"
                      Classes="accent"
                      IsVisible="{Binding IsTextMode}"
                      IsEnabled="{Binding CanRecognize}"
                      Click="ButtonRecognize_OnClick" />
            </StackPanel>
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsRecognizing}"
                         Height="4" />
            <TextBlock Text="{Binding StatusMessage}"
                       IsVisible="{Binding HasStatusMessage}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </controls:SettingsExpanderItem>
      </controls:SettingsExpander>

      <!-- 识别结果（识别成功后显示） -->
      <controls:SettingsExpander Header="识别结果"
                                 IsVisible="{Binding HasResult}"
                                 IsExpanded="True">

        <!-- 时间表 -->
        <controls:SettingsExpanderItem Content="时间表预览">
          <ItemsControl ItemsSource="{Binding ResultPeriods}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="6,3" CornerRadius="4">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{Binding Label}"
                               Width="60"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{Binding Time}"
                               VerticalAlignment="Center"
                               FontFamily="Consolas, monospace" />
                    <Border Background="{DynamicResource AccentFillColorDefaultBrush}"
                            CornerRadius="3" Padding="4,1"
                            IsVisible="{Binding IsClass}">
                      <TextBlock Text="上课" Foreground="White" FontSize="11" />
                    </Border>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </controls:SettingsExpanderItem>

        <!-- 课程列表（可编辑） -->
        <controls:SettingsExpanderItem Content="课程列表（可编辑）"
                                       Description="直接修改科目名称，导入时将自动创建对应科目">
          <ItemsControl ItemsSource="{Binding EditableClasses}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                  <TextBlock Text="{Binding Index, StringFormat='第{0}节'}"
                             Width="50" VerticalAlignment="Center"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                  <TextBox Text="{Binding Name}"
                           MinWidth="140"
                           Watermark="科目名称（留空跳过）" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </controls:SettingsExpanderItem>

      </controls:SettingsExpander>

      <!-- 导入目标 -->
      <controls:SettingsExpander Header="导入到"
                                 IsExpanded="True"
                                 IsEnabled="{Binding HasResult}">
        <controls:SettingsExpanderItem>
          <RadioButton Content="合并到当前档案"
                       IsChecked="{Binding ImportType,
                           Converter={StaticResource IntToRadioButtonSelectionConverter},
                           ConverterParameter=0}" />
        </controls:SettingsExpanderItem>
        <controls:SettingsExpanderItem>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <RadioButton Content="创建新档案"
                         IsChecked="{Binding ImportType,
                             Converter={StaticResource IntToRadioButtonSelectionConverter},
                             ConverterParameter=1}" />
            <TextBox Watermark="新档案名称"
                     Text="{Binding NewProfileName}"
                     MinWidth="180"
                     IsVisible="{Binding ImportType,
                         Converter={StaticResource IntToRadioButtonSelectionConverter},
                         ConverterParameter=1}" />
          </StackPanel>
        </controls:SettingsExpanderItem>
      </controls:SettingsExpander>

    </StackPanel>
  </ScrollViewer>
</UserControl>
